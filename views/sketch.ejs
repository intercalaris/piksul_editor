<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<link rel="stylesheet" href="/css/reset.css">
	<link rel="stylesheet" href="/css/sketchstyle.css">
	<title>Piksul - Sketch</title>
</head>
<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-TJMC7X2C2Y"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '<%= process.env.GA_TRACKING_ID %>');
</script>
<body>
	<header>
		<a href="/" class="button logo-home">
			<img id="piksul-logo" src="/img/piksul-logo.png" alt="Piksul Logo">
			<span>PIKSUL</span>
		</a>
		<div class="navigation">
			<a href="/editor" class="button start-project"><span>New Project</span></a>
			<a href="/gallery" class="button view-projects"><span>Gallery</span></a>
		</div>
		<div class="user-buttons">
			<a class="button login"><span>Log In</span></a>
			<a class="button create-account"><span>Sign Up</span></a>
			<a class="button logout hidden"><span>Log Out</span></a>
		</div>
  </header>

  	<main id="sketch"
		data-project-id="<%= project.id || '' %>"
		data-edited-image="<%= project.edited_image || '' %>"
		data-block-size="<%= project.block_size || '' %>"
		data-palette-size="<%= project.palette_size || '' %>">

    <div class="editor-container">
		<div id="canvas-container" class="canvas-container">
            <canvas id="image-canvas"></canvas>
            <canvas id="grid-canvas"></canvas>
        </div>
          
		<div class="tools-container">
			<div id = "palette-container" class="tool">
				<label for="color-picker">Choose Color:</label>
				<input type="color" id="color-picker" value="#000000">
				<div id="color-palette" class="color-palette">
				</div>	
			</div>
			<div id = "controls-container" class="tool">
				<div id="draw-erase">
					<a href="#" id="draw-button" class="button draw selected"><span>Draw</span></a>
					<a href="#" id="erase-button" class="button erase"><span>Erase</span></a>
				</div>
				<a href="#" id="paint-fill-button" class="button paint-fill"><span>Paint Fill</span></a>
				<div id="undo-reset">
					<a href="#" id="undo-button" class="button undo"><span>Undo</span></a>
					<a href="#" id="reset-button" class="button reset"><span>Reset</span></a>
				</div>
			</div>
			<div class="tool">
				<a href="#" id="save-project-button" class="button save"><span>Publish to Site</span></a>
				<div id="export-controls">
					<div id="export-scale-controls">
						<label for="export-scale-input">Scale: </label>
						<select id="export-scale-input">
							<option value="1">1x</option>
							<option value="2">2x</option>
							<option value="4">4x</option>
							<option value="8">8x</option>
							<option value="16">16x</option>
							<option value="32">32x</option>
							<option value="64">64x</option>
						</select>
					</div>
					<a href="#" id="download-button" class="button download"><span>Export</span></a>
				</div>
			</div>
		</div>
	</div>
	</main>

	<script type="text/javascript" src="/js/sketch.js"></script>
</body>
</html>
